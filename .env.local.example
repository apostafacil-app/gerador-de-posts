# ─── Autenticação ───────────────────────────────────────────────────────────
# Usuário de acesso ao sistema
ADMIN_USER=jonas

# Hash bcrypt da senha (gere com: node scripts/gerar-hash-senha.js SUA_SENHA)
ADMIN_PASS_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Segredo para assinar os tokens JWT (mínimo 32 caracteres aleatórios)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-de-pelo-menos-32-caracteres

# ─── Inteligência Artificial ────────────────────────────────────────────────
# Provider: claude | openai | gemini
AI_PROVIDER=claude

# Chave de API do provider escolhido
AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
